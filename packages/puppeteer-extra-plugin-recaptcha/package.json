{
  "name": "@ductridev/puppeteer-extra-plugin-recaptcha",
  "version": "3.7.0",
  "description": "A puppeteer-extra plugin to solve reCAPTCHAs and hCaptchas automatically.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ductridev/puppeteer-extra-plugin-recaptcha.git"
  },
  "homepage": "https://github.com/ductridev/puppeteer-extra-plugin-recaptcha#readme",
  "bugs": {
    "url": "https://github.com/ductridev/puppeteer-extra-plugin-recaptcha/issues"
  },
  "author": "ductridev",
  "license": "MIT",
  "scripts": {
    "clean": "rimraf dist",
    "tscheck": "tsc --pretty --noEmit",
    "prebuild": "run-s clean",
    "build": "run-s build:tsc build:rollup",
    "build:tsc": "tsc --project tsconfig.json --module commonjs",
    "build:rollup": "rollup -c rollup.config.ts",
    "docs": "node -e 0",
    "predocs2": "rimraf docs/*",
    "docs2": "typedoc --module commonjs --readme none --target ES6 --theme markdown --excludeNotExported --excludeExternals --excludePrivate --out docs --mode file src/index.ts",
    "test": "ava -v --config ava.config-ts.js",
    "pretest-ci": "run-s build",
    "test-ci": "ava --fail-fast --concurrency 2 -v"
  },
  "engines": {
    "node": ">=22"
  },
  "prettier": {
    "printWidth": 80,
    "semi": false,
    "singleQuote": true
  },
  "keywords": [
    "puppeteer",
    "puppeteer-extra",
    "puppeteer-extra-plugin",
    "recaptcha",
    "hcaptcha",
    "captcha",
    "2captcha"
  ],
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/node": "^24.12.0",
    "@types/puppeteer": "^7.0.4",
    "ava": "^7.0.0",
    "copyfiles": "^2.4.1",
    "npm-run-all": "^4.1.5",
    "puppeteer": "^24.39.0",
    "puppeteer-extra": "^3.3.6",
    "replace-in-files-cli": "^4.0.0",
    "rimraf": "^6.1.3",
    "rollup-plugin-commonjs": "^10.1.0",
    "rollup-plugin-node-resolve": "^5.2.0",
    "rollup-plugin-sourcemaps": "^0.6.3",
    "rollup-plugin-typescript2": "^0.36.0",
    "ts-node": "^10.9.2",
    "tslint": "^6.1.3",
    "tslint-config-prettier": "^1.18.0",
    "tslint-config-standard": "^9.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "debug": "^4.4.3",
    "merge-deep": "^3.0.3",
    "playwright-core": "^1.58.2",
    "puppeteer-extra-plugin": "^3.2.3"
  },
  "peerDependencies": {
    "playwright-extra": "*",
    "puppeteer-extra": "*"
  },
  "peerDependenciesMeta": {
    "puppeteer-extra": {
      "optional": true
    },
    "playwright-extra": {
      "optional": true
    }
  }
}
